#!/bin/bash
################################################################################
#
#  ripsacd
#
#  Simple script for ripping SACDs from a compatible Blu-ray player and
#  uploading them to a NAS via rsync. Tested on Ubuntu 20.04 LTS and Arch Linux,
#  but it may work on other Debian/Arch-based systems.
#
#  Works with these players: https://tinyurl.com/Sony-SACD-Players
#
#  More info here:
#  https://gist.github.com/willsthompson/a4ececdee9cbc4e369eb923e136a8243
#
################################################################################

sacd_server="172.16.8.184"   # IP address of your Blu-ray player.
rsync_target="files:/volume1/cd/sacd"  # where to upload sacd.
rip_flags="--2ch-tracks --output-dsf --dsf-nopad"

if [ -z "${sacd_server}" ]; then
  if [ -n "${1}" ]; then
    sacd_server="${1}"
  else
    2>&1 echo "Usage: $0 <Blu-ray player IP address>"
    exit 1
  fi
fi

if [ -z "${rsync_target}" ] && [ -n "${2}" ]; then
  rsync_target="${2}"
fi

export PATH=~/bin:$PATH
command -v sacd_extract || (
  cd ~ || exit
  mkdir -pv ~/bin

  if command -v apt-get >/dev/null 2>&1; then
    echo "Installing dependencies on Debian-based system..."
    sudo apt-get update && sudo apt-get upgrade
    sudo apt-get -y install cmake git rsync
  elif command -v pacman >/dev/null 2>&1; then
    echo "Installing dependencies on Arch Linux system..."
    sudo pacman -Syu --needed --noconfirm base-devel cmake git rsync
  else
    2>&1 echo "Only Debian and Arch Linux systems are supported. Sorry."
    exit 2
  fi

  git clone https://github.com/setmind/sacd-ripper.git
  cd sacd-ripper/tools/sacd_extract || exit
  cmake . -DCMAKE_BUILD_TYPE=RELEASE -DCMAKE_C_FLAGS="-fcommon" && make
  if [ -x ./sacd_extract ]; then
    ln sacd_extract ~/bin/
  else
    2>&1 echo "Build of sacd_extract failed. See above for details."
    exit 3
  fi
)

clean_metadata() {
  local val="$1"
  # Trim leading and trailing whitespace
  val="${val#"${val%%[![:space:]]*}"}"
  val="${val%"${val##*[![:space:]]}"}"
  # Strip surrounding quotes if they exist
  if [[ "$val" == \"*\" ]]; then
    val="${val#\"}"
    val="${val%\"}"
    # Trim whitespace again
    val="${val#"${val%%[![:space:]]*}"}"
    val="${val%"${val##*[![:space:]]}"}"
  fi
  # Remove characters that are invalid or problematic in directory names
  val="$(echo "$val" | tr -d '\\/;')"
  echo "$val"
}

# Fetch disc info once
sacd_info="$(sacd_extract --input "${sacd_server}:2002" --print)"

Artist=""
Title=""
while IFS= read -r line; do
  if [[ "$line" =~ ^[[:space:]]+([^:]+):[[:space:]]*(.*)$ ]]; then
    key="${BASH_REMATCH[1]}"
    val="${BASH_REMATCH[2]}"
    if [[ "$key" == "Artist" && -z "$Artist" ]]; then
      Artist="$val"
    elif [[ "$key" == "Title" && -z "$Title" ]]; then
      Title="$val"
    fi
  fi
done <<< "$sacd_info"

Artist="$(clean_metadata "${Artist}")"
Title="$(clean_metadata "${Title}")"

# If metadata is missing, prompt the user for input
if [ -z "${Artist}" ] || [ -z "${Title}" ]; then
  echo "Metadata not found on disc. Please enter details manually."
  if [ -z "${Artist}" ]; then
    read -rp "Artist: " Artist
  fi
  if [ -z "${Title}" ]; then
    read -rp "Album Title: " Title
  fi
fi

# Final check to ensure we aren't creating an empty path
if [ -z "${Artist}" ] || [ -z "${Title}" ]; then
  2>&1 echo "Error: Artist and Title are required to continue."
  exit 4
fi

output="${HOME}/sacd/${Artist}/${Title} (SACD)"
umask 002
mkdir -pv "${output}"

echo "----------------------------------------"
echo "Ripping ${Title} on $(date)"
# shellcheck disable=SC2086
sacd_extract --input "${sacd_server}:2002" ${rip_flags} --output-dir "${output}"

# shellcheck disable=SC2010
tmpdir="$(ls "${output}" | grep -v '\.dsf$')"
if [ -n "${tmpdir}" ]; then
  echo "----------------------------------------"
  echo "Rip complete on $(date)"
  mv "${output}"/"${tmpdir}"/*.dsf "${output}" && rmdir "${output}"/"${tmpdir}"
  if [ -n "${rsync_target}" ]; then
    rsync -avui --progress --stats --rsync-path=/usr/bin/rsync "${HOME}/sacd" "${rsync_target}"
  fi
else
  2>&1 echo "Rip failed. See output above."
  exit 5
fi
